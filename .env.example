# Postgres connection for Vyper's database.
# Create a database (e.g. `createdb vyper`) and point this at it.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/vyper

# Port for the Vyper API server (Vite dev proxies /api to this).
PORT=8787

# --- Desktop app (Electron) ---
# The desktop build stores data in an embedded PGlite database and works fully
# offline. If DATABASE_URL is set AND reachable, it also syncs against that
# Postgres in the background (newest updatedAt wins); if not, it stays embedded.
